# DataVaidya secrets template.
# Copy this file to `.streamlit/secrets.toml` and replace the placeholders.
# `secrets.toml` is gitignored — never commit real keys.
#
# Where to get keys:
#   - GROQ_API_KEY:   https://console.groq.com/keys
#                     (sign in, click "Create API Key", copy the gsk_... value)
#   - GEMINI_API_KEY: https://aistudio.google.com/app/apikey
#                     (Google AI Studio → "Create API key", copy the AIza... value)

GROQ_API_KEY = "gsk_REPLACE_ME_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
GEMINI_API_KEY = "AIzaSyREPLACE_ME_xxxxxxxxxxxxxxxxxxxxxxxx"

[app]
default_llm_provider = "groq"   # 'groq' or 'gemini'
enable_telemetry = false
